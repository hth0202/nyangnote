rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Cat access via membership
    match /cats/{catId} {
      function isMember() {
        return exists(/databases/$(database)/documents/cats/$(catId)/members/$(request.auth.uid));
      }
      function isOwner() {
        return get(/databases/$(database)/documents/cats/$(catId)/members/$(request.auth.uid)).data.role == 'owner';
      }

      allow read: if request.auth != null && isMember();
      allow create: if request.auth != null;
      allow update: if request.auth != null && isOwner();
      allow delete: if request.auth != null && isOwner();

      match /members/{memberId} {
        allow read: if request.auth != null && isMember();
        allow write: if request.auth != null && isOwner();
        // Allow self-join on invite accept
        allow create: if request.auth != null && request.auth.uid == memberId;
      }

      match /invites/{inviteId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && isOwner();
        allow update: if request.auth != null && (isOwner() || resource.data.status == 'pending');
      }

      match /records/{recordId} {
        allow read: if request.auth != null && isMember();
        allow create: if request.auth != null && isMember();
        allow update: if request.auth != null && (
          isOwner() || (isMember() && resource.data.userId == request.auth.uid)
        );
        allow delete: if request.auth != null && isOwner();
      }
    }

    // Invite codes — top-level collection for code-based lookup
    match /inviteCodes/{code} {
      // Any authenticated user can look up a code
      allow read: if request.auth != null;
      // Any authenticated user can create (owner check is enforced by app logic)
      allow create: if request.auth != null;
      // Allow status updates (accept / expire / cancel) by any authenticated user
      allow update: if request.auth != null;
    }
  }
}
